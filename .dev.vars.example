# Local development secrets for the Cloudflare Worker (loaded by `npm run dev`).
# Copy this file to `.dev.vars` and fill in your real key. `.dev.vars` is gitignored.
#
# Get a key at https://aistudio.google.com/app/apikey

GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: override the Gemini model (defaults to gemini-3.5-flash).
# GEMINI_MODEL="gemini-3.5-flash"
