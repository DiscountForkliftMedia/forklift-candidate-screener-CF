# Local development secrets for the Cloudflare Worker (loaded by `npm run dev`).
# Copy this file to `.dev.vars` and fill in your real key. `.dev.vars` is gitignored.
#
# Get a key at https://platform.openai.com/api-keys

OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: override the model (defaults to gpt-4o-mini).
# Must be a model that supports Structured Outputs (json_schema), e.g. gpt-4o, gpt-4o-mini, gpt-4.1.
# OPENAI_MODEL="gpt-4o-mini"
